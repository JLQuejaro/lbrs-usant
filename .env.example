# ============================================================
# USANT LBRS - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Prisma / PostgreSQL connection strings
# Point both URLs at the same shared Postgres database unless you use a separate
# direct connection for migrations. Prefer a managed host and SSL in non-local environments.
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/lbrs_db?schema=public&sslmode=require
DIRECT_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/lbrs_db?schema=public&sslmode=require

# Prisma Studio
PRISMA_STUDIO_PORT=5555

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Next.js Application
NEXT_PUBLIC_APP_NAME=USANT LBRS
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Environment
NODE_ENV=development

# ============================================================
# AUTHENTICATION (For future implementation)
# ============================================================

# JWT Secret (generate a strong random string)
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Session Configuration
SESSION_MAX_AGE=7d

# ============================================================
# FILE STORAGE (For ID documents, etc.)
# ============================================================

# Local storage path for uploaded files
UPLOAD_PATH=./uploads

# Maximum file size in bytes (default: 5MB)
MAX_FILE_SIZE=5242880

# ============================================================
# EMAIL CONFIGURATION (For notifications - future)
# ============================================================

# SMTP Settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@usant.edu
# SMTP_PASSWORD=your_app_password

# Email From Address
# EMAIL_FROM=noreply@usant.edu

# ============================================================
# SECURITY
# ============================================================

# Bcrypt salt rounds for password hashing
BCRYPT_SALT_ROUNDS=10

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================
# PRODUCTION SETTINGS (Optional)
# ============================================================

# Database SSL or additional query params can be appended directly to the
# connection string, for example: ?schema=public&sslmode=require

# Redis for caching (optional)
# REDIS_URL=rediss://CACHE_USER:CACHE_PASSWORD@CACHE_HOST:6379

# ============================================================
# DEVELOPMENT ONLY
# ============================================================

# Enable debug logging
DEBUG=true

# Log database queries
LOG_DB_QUERIES=true

# Seed mock data on startup (development only)
SEED_MOCK_DATA=false
